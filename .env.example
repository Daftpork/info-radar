# ============ LLM provider（复刻 Lumio：yuyu → liaobots → anthropic）============
# 主 provider：yuyu（yylx / 鱼鱼连线），OpenAI 兼容
YUYU_API_KEY=
YUYU_BASE_URL=https://app.yylx.io/v1
# 备用 provider：liaobots，OpenAI 兼容
LIAOBOTS_API_KEY=
LIAOBOTS_BASE_URL=https://ai.liaobots.work/v1
# 兜底：Anthropic 官方（可选，不填则跳过这一级）
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=            # 若走中转再填
# 模型档位（网关自定义命名，一般不用改）
# RADAR_MODEL=gpt-5.4-mini
# RADAR_HEAVY_MODEL=gpt-5.5

# ============ 播客音频转录（Whisper API，可选；不填则播客用 show notes）============
# 推荐 Groq（有免费额度）: WHISPER_BASE_URL=https://api.groq.com/openai/v1  WHISPER_MODEL=whisper-large-v3-turbo
# 或 OpenAI: WHISPER_BASE_URL=https://api.openai.com/v1  WHISPER_MODEL=whisper-1
WHISPER_API_KEY=
WHISPER_BASE_URL=https://api.groq.com/openai/v1
WHISPER_MODEL=whisper-large-v3-turbo

# ============ 数据源 ============
# Product Hunt 走公开 RSS，无需 token（官方 API 已限申请）
# GitHub API（本地填 PAT 提额度；GitHub Actions 里自动注入 GITHUB_TOKEN）
GITHUB_TOKEN=
# Exa 语义搜索（行业深潜深挖用，可选）
EXA_API_KEY=

# ============ 邮件送达（Gmail SMTP + 应用专用密码）============
EMAIL_FROM=you@gmail.com
EMAIL_PASSWORD=            # Gmail 应用专用密码（非登录密码）
EMAIL_TO=you@qq.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ============ 网页 + 订阅（Buttondown；配了就走订阅者，否则回落上面的 Gmail）============
# Buttondown：注册后在 Settings 拿 API key + 用户名
BUTTONDOWN_API_KEY=
BUTTONDOWN_USERNAME=            # 用于网页订阅表单
# BUTTONDOWN_API_BASE=https://api.buttondown.email/v1   # 一般不用改
# 站点基址（部署后填，digest 里才会放「全文+详解」链接）
RADAR_SITE_BASE=
RADAR_SITE_TITLE=信息雷达
